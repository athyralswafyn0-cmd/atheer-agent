datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider        = "prisma-client-js"
  output          = "../node_modules/.prisma/client"
}

model Widget {
  id          String   @id @default(uuid())
  name        String
  description String?
  code        String   @unique
  config      Json?
  isActive    Boolean  @default(true)
  orgId       String
  botId       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([orgId])
  @@index([botId])
  @@index([code])
}