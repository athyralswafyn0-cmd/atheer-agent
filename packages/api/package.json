    "@fastify/static": "^6.0.0",
    "@google/generative-ai": "^0.24.1",
    "@opentelemetry/api": "^1.9.1",
    "@opentelemetry/exporter-jaeger": "^2.9.0",
    "@opentelemetry/instrumentation": "^0.220.0",
    "@opentelemetry/instrumentation-fastify": "^0.57.0",
