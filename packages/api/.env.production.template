# =============================================================================
# Atheer Agent AI - MONOLITH API PRODUCTION ENVIRONMENT
# =============================================================================
# Copy to .env.production and fill in all required values
# Never commit this file - use Render Dashboard Environment Variables instead
# =============================================================================

# Database (Supabase PostgreSQL or Render PostgreSQL)
DATABASE_URL=postgresql://username:password@host:5432/database_name

# Server
NODE_ENV=production
PORT=10000
HOST=0.0.0.0

# Authentication (JWT)
# Generate with: openssl rand -base64 32
JWT_SECRET=
JWT_EXPIRES_IN=7d

# Password Hashing
BCRYPT_ROUNDS=12

# CORS Origins (comma-separated)
CORS_ORIGINS=https://www.atheersolutions.online,https://atheersolutions.online,https://dashboard.atheersolutions.online

# Redis (Optional - Upstash free tier)
REDIS_URL=

# AI Providers (Optional - add when needed)
GROQ_API_KEY=
GROQ_MODEL=llama-3.1-70b-versatile
GOOGLE_AI_API_KEY=
GOOGLE_AI_MODEL=gemini-1.5-flash
EMBEDDING_PROVIDER=google
EMBEDDING_MODEL=text-embedding-004

# Email (Optional)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@atheersolutions.online

# Frontend URL (for email links, etc.)
FRONTEND_URL=https://dashboard.atheersolutions.online
WIDGET_CDN_URL=https://www.atheersolutions.online/widget