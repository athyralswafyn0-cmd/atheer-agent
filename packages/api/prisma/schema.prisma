generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                   String              @id @default(cuid())
  email                String              @unique
  passwordHash         String?
  name                 String?
  avatar               String?
  role                 UserRole            @default(MEMBER)
  emailVerified        DateTime?
  lastLoginAt          DateTime?
  lastLoginIp          String?
  loginAttempts        Int                 @default(0)
  lockedUntil          DateTime?
  passwordResetExpires DateTime?
  passwordResetToken   String?             @unique
  twoFactorSecret      String?
  twoFactorEnabled     Boolean             @default(false)
  backupCodes          String[]
  createdAt            DateTime            @default(now())
  updatedAt            DateTime            @updatedAt
  isActive             Boolean             @default(true)
  deletedAt            DateTime?
  lastPasswordChange   DateTime            @default(now())
  preferredLanguage    String              @default("ar")
  timezone             String              @default("UTC")
  organizationId       String?
  organization         Organization?       @relation("UserOrganization", fields: [organizationId], references: [id])

  accounts             Account[]
  activities           Activity[]
  apiKeys              ApiKey[]
  notifications        Notification[]
  organizationMembers  OrganizationMember[]
  sessions             Session[]
  ownedBots            Bot[]               @relation("BotOwner")
  passwordResetTokens  PasswordResetToken[]

  @@index([email])
  @@index([organizationId])
  @@index([role])
  @@index([deletedAt])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  token     String   @unique
  userId    String
  expires   DateTime
  used      Boolean  @default(false)
  usedAt    DateTime?
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expires])
}

model Organization {
  id            String               @id @default(cuid())
  name          String
  slug          String               @unique
  domain        String?              @unique
  logo          String?
  description   String?
  industry      String?
  size          String?
  website       String?
  email         String?
  phone         String?
  address       String?
  city          String?
  country       String?
  status        String               @default("active")
  plan          String               @default("starter")
  settings      Json                 @default("{}")
  createdAt     DateTime             @default(now())
  updatedAt     DateTime             @updatedAt
  licenseId     String?              @unique
  partnerId     String?
  activities    Activity[]
  apiKeys       ApiKey[]
  bots          Bot[]
  brand         Brand?               @relation("BrandOrganization")
  conversations Conversation[]
  integrations  Integration[]
  invitations   Invitation[]
  leads         Lead[]               @relation("OrganizationLeads")
  notifications Notification[]
  license       License?             @relation("LicenseOrganization", fields: [licenseId], references: [id])
  members       OrganizationMember[]
  usage         Usage[]
  partners      Partner[]            @relation("OrganizationPartners")
  users         User[]               @relation("UserOrganization")

  @@index([slug])
  @@index([domain])
  @@index([status])
}

model OrganizationMember {
  id             String       @id @default(cuid())
  userId         String
  organizationId String
  role           UserRole     @default(MEMBER)
  joinedAt       DateTime     @default(now())
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, organizationId])
  @@index([organizationId])
}

model Invitation {
  id             String       @id @default(cuid())
  email          String
  role           UserRole
  organizationId String
  invitedBy      String
  token          String       @unique
  expiresAt      DateTime
  acceptedAt     DateTime?
  createdAt      DateTime     @default(now())
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([email, organizationId])
  @@index([token])
}

model Bot {
  id                   String                @id @default(cuid())
  name                 String
  description          String?
  type                 BotType               @default(CUSTOM)
  status               BotStatus             @default(INACTIVE)
  avatar               String?
  primaryColor         String                @default("#2563eb")
  secondaryColor       String                @default("#ffffff")
  position             String                @default("bottom-right")
  welcomeMessage       String                @default("مرحباً! كيف يمكنني مساعدتك اليوم؟")
  placeholder          String                @default("اكتب رسالتك هنا...")
  showBranding         Boolean               @default(true)
  language             String                @default("ar")
  supportedLanguages   String[]              @default(["ar", "en"])
  model                String                @default("gpt-4-turbo-preview")
  temperature          Float                 @default(0.7)
  maxTokens            Int                   @default(2000)
  systemPrompt         String
  fallbackMessage      String                @default("عذراً، لم أفهم طلبك. هل يمكنك إعادة الصياغة؟")
  trainingStatus       String                @default("pending")
  lastTrainedAt        DateTime?
  trainingError        String?
  collectLeads         Boolean               @default(false)
  leadFields           Json                  @default("[]")
  notifyOnLead         Boolean               @default(true)
  notificationChannels NotificationChannel[] @default([EMAIL])
  notificationEmails   String[]              @default([])
  totalConversations   Int                   @default(0)
  totalMessages        Int                   @default(0)
  avgResponseTime      Float                 @default(0)
  satisfactionRate     Float                 @default(0)
  organizationId       String
  ownerId              String
  createdAt            DateTime              @default(now())
  updatedAt            DateTime              @updatedAt
  queueName            String?               @unique
  activities           Activity[]
  organization         Organization          @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  owner                User                  @relation("BotOwner", fields: [ownerId], references: [id], map: "Bot_owner_fkey")
  conversations        Conversation[]
  embedScripts         EmbedScript?
  knowledgeBases       KnowledgeBase[]
  leads                Lead[]
  trainingJobs         TrainingJob[]

  @@index([organizationId])
  @@index([status])
  @@index([ownerId])
}

model KnowledgeBase {
  id          String           @id @default(cuid())
  name        String
  type        String
  source      String
  content     String?
  chunksCount Int              @default(0)
  status      String           @default("processing")
  error       String?
  metadata    Json             @default("{}")
  botId       String
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  bot         Bot              @relation(fields: [botId], references: [id], onDelete: Cascade)
  chunks      KnowledgeChunk[]

  @@index([botId])
  @@index([status])
}

model KnowledgeChunk {
  id              String                @id @default(cuid())
  content         String
  embedding       Json?                 // Store embeddings as JSON array for pgvector-free deployments
  chunkIndex      Int
  tokens          Int
  metadata        Json                  @default("{}")
  knowledgeBaseId String
  knowledgeBase   KnowledgeBase         @relation(fields: [knowledgeBaseId], references: [id], onDelete: Cascade)

  @@index([knowledgeBaseId])
  @@index([chunkIndex])
}

model TrainingJob {
  id              String    @id @default(cuid())
  botId           String
  status          String    @default("pending")
  progress        Int       @default(0)
  totalChunks     Int       @default(0)
  processedChunks Int       @default(0)
  error           String?
  startedAt       DateTime?
  completedAt     DateTime?
  metadata        Json      @default("{}")
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  bot             Bot       @relation(fields: [botId], references: [id], onDelete: Cascade)

  @@index([botId])
  @@index([status])
  @@index([createdAt])
}

model Conversation {
  id              String             @id @default(cuid())
  sessionId       String             @unique
  visitorId       String?
  userIp          String?
  userAgent       String?
  language        String             @default("ar")
  status          ConversationStatus @default(ACTIVE)
  metadata        Json               @default("{}")
  startedAt       DateTime           @default(now())
  endedAt         DateTime?
  rating          Int?
  feedback        String?
  messageCount    Int                @default(0)
  avgResponseTime Float?
  lastMessageAt   DateTime?
  botId           String
  organizationId  String
  bot             Bot                @relation(fields: [botId], references: [id], onDelete: Cascade)
  organization    Organization       @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  lead            Lead?
  messages        Message[]

  @@index([botId])
  @@index([sessionId])
  @@index([startedAt])
  @@index([status])
  @@index([organizationId])
}

model Message {
  id             String       @id @default(cuid())
  role           MessageRole
  content        String
  tokens         Int?
  model          String?
  metadata       Json         @default("{}")
  conversationId String
  createdAt      DateTime     @default(now())
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([conversationId])
  @@index([createdAt])
}

model Lead {
  id             String        @id @default(cuid())
  name           String?
  email          String?
  phone          String?
  company        String?
  position       String?
  customData     Json          @default("{}")
  status         LeadStatus    @default(NEW)
  source         String        @default("chat_widget")
  utmSource      String?
  utmMedium      String?
  utmCampaign    String?
  utmContent     String?
  utmTerm        String?
  assignedTo     String?
  notes          String?
  score          Int?          @default(0)
  botId          String
  conversationId String?       @unique
  organizationId String?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  convertedAt    DateTime?
  bot            Bot           @relation(fields: [botId], references: [id], onDelete: Cascade)
  conversation   Conversation? @relation(fields: [conversationId], references: [id])
  organization   Organization? @relation("OrganizationLeads", fields: [organizationId], references: [id])

  @@index([botId])
  @@index([status])
  @@index([email])
  @@index([createdAt])
}

model EmbedScript {
  id            String   @id @default(cuid())
  domain        String   @unique
  allowed       Boolean  @default(true)
  scriptVersion String   @default("1.0.0")
  botId         String   @unique
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  bot           Bot      @relation(fields: [botId], references: [id], onDelete: Cascade)

  @@index([domain])
}

model Integration {
  id             String       @id @default(cuid())
  name           String
  type           String
  config         Json         @default("{}")
  isActive       Boolean      @default(true)
  lastSyncAt     DateTime?
  lastError      String?
  organizationId String
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([type])
}

model Activity {
  id             String       @id @default(cuid())
  action         String
  entityType     String
  entityId       String
  metadata       Json         @default("{}")
  ipAddress      String?
  userAgent      String?
  userId         String?
  botId          String?
  organizationId String
  createdAt      DateTime     @default(now())
  bot            Bot?         @relation(fields: [botId], references: [id])
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user           User?        @relation(fields: [userId], references: [id])

  @@index([organizationId])
  @@index([userId])
  @@index([botId])
  @@index([createdAt])
}

model Notification {
  id             String              @id @default(cuid())
  type           String
  title          String
  message        String
  channel        NotificationChannel
  recipient      String
  status         String              @default("pending")
  metadata       Json                @default("{}")
  error          String?
  sentAt         DateTime?
  userId         String?
  organizationId String
  createdAt      DateTime            @default(now())
  organization   Organization        @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user           User?               @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([status])
  @@index([createdAt])
}

model ApiKey {
  id             String       @id @default(cuid())
  name           String
  keyHash        String       @unique
  prefix         String       @unique
  permissions    String[]     @default(["chat:read", "chat:write"])
  lastUsedAt     DateTime?
  expiresAt      DateTime?
  isActive       Boolean      @default(true)
  organizationId String
  userId         String?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user           User?        @relation(fields: [userId], references: [id])

  @@index([organizationId])
  @@index([prefix])
}

model Partner {
  id            String         @id @default(cuid())
  name          String
  email         String         @unique
  passwordHash  String?
  isActive      Boolean        @default(true)
  licenseId     String?        @unique
  brandId       String?        @unique
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  brand         Brand?         @relation("PartnerBrand")
  license       License?       @relation("PartnerLicense")
  organizations Organization[] @relation("OrganizationPartners")

  @@index([email])
}

model License {
  id                   String        @id @default(cuid())
  plan                 String
  partnerId            String        @unique
  expiresAt            DateTime
  maxOrganizations     Int           @default(10)
  maxBots              Int           @default(50)
  maxUsers             Int           @default(100)
  maxMessages          Int           @default(100000)
  maxStorage           Int           @default(10000)
  status               String        @default("active")
  stripeSubscriptionId String?
  stripeCustomerId     String?
  createdAt            DateTime      @default(now())
  updatedAt            DateTime      @updatedAt
  partner              Partner       @relation("PartnerLicense", fields: [partnerId], references: [id])
  organization         Organization? @relation("LicenseOrganization")

  @@index([partnerId])
  @@index([status])
  @@index([expiresAt])
}

model Brand {
  id              String        @id @default(cuid())
  partnerId       String?       @unique
  organizationId  String?       @unique
  logo            String?
  favicon         String?
  brandName       String?
  primaryColor    String        @default("#2563eb")
  secondaryColor  String        @default("#ffffff")
  font            String?
  emailSender     String?
  supportEmail    String?
  supportPhone    String?
  customDomain    String?       @unique
  privacyPolicy   String?
  terms           String?
  footer          String?
  loginBackground String?
  faviconDark     String?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  organization    Organization? @relation("BrandOrganization", fields: [organizationId], references: [id])
  partner         Partner?      @relation("PartnerBrand", fields: [partnerId], references: [id])

  @@index([partnerId])
  @@index([organizationId])
  @@index([customDomain])
}

model Usage {
  id             String       @id @default(cuid())
  organizationId String
  date           DateTime     @db.Date
  messages       Int          @default(0)
  conversations  Int          @default(0)
  leads          Int          @default(0)
  storageMB      Int          @default(0)
  tokensUsed     Int          @default(0)
  apiCalls       Int          @default(0)
  llmCost        Float        @default(0)
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([organizationId, date])
  @@index([organizationId])
  @@index([date])
}

enum UserRole {
  OWNER
  ADMIN
  MEMBER
  VIEWER
  PARTNER_ADMIN
  PARTNER_VIEWER
}

enum BotStatus {
  ACTIVE
  INACTIVE
  TRAINING
  ERROR
}

enum BotType {
  CUSTOMER_SUPPORT
  LEAD_GENERATION
  APPOINTMENT_BOOKING
  PRODUCT_RECOMMENDATION
  FAQ
  CUSTOM
}

enum MessageRole {
  USER
  ASSISTANT
  SYSTEM
}

enum ConversationStatus {
  ACTIVE
  CLOSED
  ESCALATED
  PENDING
}

enum LeadStatus {
  NEW
  CONTACTED
  QUALIFIED
  CONVERTED
  LOST
}

enum NotificationChannel {
  EMAIL
  TELEGRAM
  SLACK
  WEBHOOK
}
