services:
  kong:
    image: kong:latest
    container_name: kong
    ports:
      - "8000:8000"
      - "8001:8001"
      - "8443:8443"
      - "8444:8444"
    environment:
      - KONG_DATABASE=off
      - KONG_DECLARATIVE_CONFIG=/kong/kong.yml
      - KONG_PROXY_ACCESS_LOG=/dev/stdout
      - KONG_ADMIN_ACCESS_LOG=/dev/stdout
      - KONG_PROXY_ERROR_LOG=/dev/stderr
      - KONG_ADMIN_ERROR_LOG=/dev/stderr
      - KONG_ADMIN_LISTEN=0.0.0.0:8001, 0.0.0.0:8444 ssl
    volumes:
      - ./kong:/kong
      - ./kong/kong.yml:/kong/kong.yml
    networks:
      - atheer-network

  auth-service:
    build: ./services/auth-service
    container_name: auth-service
    environment:
      - DATABASE_URL=postgresql://user:password@auth-db:5432/auth_db?schema=public
      - JWT_SECRET=${JWT_SECRET:-supersecretkeychangemeinproduction}
      - PORT=3001
      - HOST=0.0.0.0
      - NODE_ENV=development
    ports:
      - "3001:3001"
    depends_on:
      - auth-db
    networks:
      - atheer-network

  auth-db:
    image: postgres:15-alpine
    container_name: auth-db
    environment:
      - POSTGRES_USER=user
      - POSTGRES_PASSWORD=password
      - POSTGRES_DB=auth_db
    volumes:
      - auth-db-data:/var/lib/postgresql/data
      - ./auth-db-data:/var/lib/postgresql/data
    networks:
      - atheer-network

networks:
  atheer-network:
    driver: bridge

volumes:
  auth-db-data: