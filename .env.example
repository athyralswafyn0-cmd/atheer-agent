# Atheer Agent AI - Environment Configuration

# ============================================================================
# APPLICATION
# ============================================================================
NODE_ENV=development
PORT=8080
HOST=0.0.0.0
APP_VERSION=1.0.0

# ============================================================================
# DATABASE
# ============================================================================
# Format: postgresql://user:password@host:port/database?schema=public
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/atheer_agent?schema=public

# For production with connection pooling:
# DATABASE_URL=postgresql://user:pass@host:5432/db?pgbouncer=true&connection_limit=20

# ============================================================================
# REDIS
# ============================================================================
REDIS_URL=redis://localhost:6379
CACHE_DEFAULT_TTL=300

# ============================================================================
# AUTHENTICATION & SECURITY
# ============================================================================
# Generate with: openssl rand -hex 32
JWT_SECRET=your-super-secret-jwt-key-change-in-production-min-32-chars
JWT_EXPIRES_IN=7d
JWT_REFRESH_EXPIRES_IN=30d

# Password hashing
BCRYPT_ROUNDS=12

# Rate limiting
RATE_LIMIT_MAX=100
RATE_LIMIT_WINDOW=1 minute

# CORS
CORS_ORIGINS=http://localhost:3000,http://localhost:3001,http://localhost:8080

# ============================================================================
# OPENAI / AI PROVIDERS
# ============================================================================
OPENAI_API_KEY=sk-your-openai-api-key
OPENAI_MODEL=gpt-4o
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# Fallback models
OPENAI_FALLBACK_MODELS=gpt-4o-mini,gpt-4-turbo,claude-3-sonnet

# Anthropic (optional)
ANTHROPIC_API_KEY=

# Cohere for reranking (optional)
COHERE_API_KEY=

# Local models (Ollama)
OLLAMA_BASE_URL=http://localhost:11434

# ============================================================================
# PAYPAL BILLING
# ============================================================================
PAYPAL_CLIENT_ID=your-paypal-client-id
PAYPAL_CLIENT_SECRET=your-paypal-client-secret
PAYPAL_WEBHOOK_SECRET=your-paypal-webhook-secret
PAYPAL_MODE=sandbox # or live
PAYPAL_WEBHOOK_URL=https://your-domain.com/api/v1/billing/webhook

# ============================================================================
# EMAIL (SMTP)
# ============================================================================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
SMTP_FROM=noreply@atheer-agent.com

# Alternative: SendGrid
# SENDGRID_API_KEY=

# ============================================================================
# FILE STORAGE (S3 Compatible)
# ============================================================================
S3_ENDPOINT=https://s3.amazonaws.com
S3_BUCKET=atheer-agent-files
S3_ACCESS_KEY=your-access-key
S3_SECRET_KEY=your-secret-key
S3_REGION=us-east-1

# For MinIO local development:
# S3_ENDPOINT=http://localhost:9000
# S3_BUCKET=atheer-agent
# S3_ACCESS_KEY=minioadmin
# S3_SECRET_KEY=minioadmin
# S3_REGION=us-east-1

# ============================================================================
# FRONTEND & WIDGET
# ============================================================================
FRONTEND_URL=http://localhost:3000
WIDGET_CDN_URL=http://localhost:8080/widget

# ============================================================================
# OBSERVABILITY
# ============================================================================
OTEL_ENABLED=false
JAEGER_ENDPOINT=http://localhost:14268/api/traces
SENTRY_DSN=
DATADOG_API_KEY=

# ============================================================================
# FEATURE FLAGS
# ============================================================================
FEATURE_RAG_ENABLED=true
FEATURE_VOICE_ENABLED=false
FEATURE_ANALYTICS_ENABLED=true
FEATURE_WHITE_LABEL_ENABLED=true

# ============================================================================
# DEVELOPMENT
# ============================================================================
DEBUG=false
LOG_LEVEL=info